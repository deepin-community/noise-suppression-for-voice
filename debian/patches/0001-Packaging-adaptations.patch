Description: Packaging adaptations for Debian/deepin LADSPA-only build
  - Remove vendored JUCE/FST/catch2, src/juce_plugin, and toolchains
    (directories deleted via Files-Excluded in debian/copyright)
  - Enable testing at top-level for CTest
  - Use system libcatch2-dev (Catch2 v3) instead of vendored catch2 v2:
      - Migrate test header: #include <catch.hpp> → #include <catch2/catch_all.hpp>
      - Remove #define CATCH_CONFIG_MAIN; link Catch2::Catch2WithMain instead
      - find_package(Catch2 3 CONFIG REQUIRED) enforces minimum v3 and config mode;
        Catch2Config.cmake appends /usr/lib/cmake/Catch2/ to CMAKE_MODULE_PATH,
        where Debian ships catch_discover_tests as Catch.cmake (not Catch2.cmake).
        Hence include(Catch), not include(Catch2).
  Non-LADSPA plugins (VST/VST3/LV2/AU/AUv3) are disabled at build time via
  -D flags in debian/rules, not by patching CMakeLists.txt options.
Author: Chengyi Zhao <zhaochengyi@uniontech.com>
Forwarded: not-needed
Last-Update: 2026-07-01

--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -25,7 +25,7 @@
 option(BUILD_RTCD "Enable x86 run-time CPU detection (x86 only)" OFF)
 
 if (BUILD_TESTS)
-    list(APPEND CMAKE_MODULE_PATH ${CMAKE_CURRENT_SOURCE_DIR}/external/catch2/)
+    enable_testing()
 endif ()
 
 add_subdirectory(external/rnnoise)
--- a/src/common/CMakeLists.txt
+++ b/src/common/CMakeLists.txt
@@ -30,13 +30,13 @@ if (BUILD_TESTS)
             ${COMMON_SRC})
     add_executable(common_plugin_tests ${TESTS_SRC})
     target_include_directories(common_plugin_tests PRIVATE
-            $<BUILD_INTERFACE:${CMAKE_SOURCE_DIR}/external/catch2>
             $<BUILD_INTERFACE:${CMAKE_CURRENT_SOURCE_DIR}/include>)
-    target_link_libraries(common_plugin_tests PRIVATE ${LIBRARIES})
     target_compile_options(common_plugin_tests PRIVATE -fsanitize=undefined)
     target_link_options(common_plugin_tests PRIVATE -fsanitize=undefined)
 
     include(CTest)
+    find_package(Catch2 3 CONFIG REQUIRED)
+    target_link_libraries(common_plugin_tests PRIVATE ${LIBRARIES} Catch2::Catch2WithMain)
     include(Catch)
     catch_discover_tests(common_plugin_tests)
 endif ()
--- a/src/common/src/tests/tests.cpp
+++ b/src/common/src/tests/tests.cpp
@@ -1,5 +1,4 @@
-#define CATCH_CONFIG_MAIN
-#include <catch.hpp>
+#include <catch2/catch_all.hpp>
 
 #include "common/RnNoiseCommonPlugin.h"
 
